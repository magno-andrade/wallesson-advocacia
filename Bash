<!DOCTYPE html>
<html lang="pt-BR">

<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Advocacia</title>

  <!-- FONTES -->

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    :root{
      --vinho:#2B0505;
      --bege:#EAD7C0;
    }

    body{
      background:#f5f5f5;
      font-family:'Poppins', sans-serif;

      min-height:100vh;

      display:flex;
      justify-content:center;
      align-items:center;

      padding:30px;
    }

    .container{
      width:100%;
      max-width:1300px;

      display:grid;
      grid-template-columns:1.3fr 1fr;

      gap:40px;
    }

    .left{
      padding:20px;
    }

    .title{
      font-family:'Playfair Display', serif;
      font-size:60px;
      color:var(--vinho);

      margin-bottom:10px;
    }

    .subtitle{
      font-size:22px;
      color:#555;

      margin-bottom:40px;
    }

    .card{
      background:white;

      border-radius:20px;

      padding:30px;

      display:flex;
      align-items:center;
      gap:25px;

      margin-bottom:25px;

      text-decoration:none;

      box-shadow:0 5px 18px rgba(0,0,0,0.15);

      transition:0.3s;
    }

    .card:hover{
      transform:translateY(-5px);
    }

    .icon{
      width:80px;
      height:80px;

      background:var(--vinho);

      border-radius:15px;

      display:flex;
      justify-content:center;
      align-items:center;

      color:var(--bege);

      font-size:40px;
    }

    .text h2{
      font-family:'Playfair Display', serif;

      font-size:30px;
      color:var(--vinho);

      margin-bottom:5px;
    }

    .text p{
      color:#555;
    }

    .right{
      background:var(--vinho);

      border-radius:40px;

      padding:50px;

      color:var(--bege);

      min-height:650px;

      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .logo{
      text-align:center;

      font-family:'Playfair Display', serif;

      font-size:28px;

      margin-bottom:50px;
    }

    .main-text{
      font-family:'Playfair Display', serif;

      font-size:42px;

      line-height:1.3;
    }

    .benefits{
      display:flex;
      flex-direction:column;

      gap:30px;
    }

    .benefit h3{
      margin-bottom:5px;
    }

    .benefit p{
      color:#f1e4d6;
    }

  </style>

</head>

<body>

  <div class="container">

    <div class="left">

      <h1 class="title">
        Criar conta
      </h1>

      <p class="subtitle">
        Escolha o tipo de conta que melhor descreve você
      </p>

      <!-- BOTÃO CLIENTE -->

      <a href="cliente/index.html" class="card">

        <div class="icon">
          👤
        </div>

        <div class="text">

          <h2>
            Sou cliente
          </h2>

          <p>
            Acesse sua área e acompanhe seus processos.
          </p>

        </div>

      </a>

      <!-- BOTÃO ADVOGADO -->

      <a href="advogado/index.html" class="card">

        <div class="icon">
          ⚖️
        </div>

        <div class="text">

          <h2>
            Sou advogado
          </h2>

          <p>
            Conferir seus processos.
          </p>

        </div>

      </a>

    </div>

    <!-- LADO DIREITO -->

    <div class="right">

      <div>

        <div class="logo">

          CAVALCANTE<br>
          ADVOCACIA

        </div>

        <div class="main-text">

          Segurança e confiança
          para cuidar do que
          realmente importa.

        </div>

      </div>

      <div class="benefits">

        <div class="benefit">

          <h3>
            Ambiente seguro
          </h3>

          <p>
            Protegemos seus dados
          </p>

        </div>

        <div class="benefit">

          <h3>
            Acesso simplificado
          </h3>

          <p>
            Tudo que você precisa em um só lugar
          </p>

        </div>

        <div class="benefit">

          <h3>
            Suporte especializado
          </h3>

          <p>
            Nossa equipe está sempre à disposição
          </p>

        </div>

      </div>

    </div>

  </div>

</body>

</html>